# Copy this file to .env and fill in real values.
# The .env file must never be committed to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?pgbouncer=true

# ── Source system (ERP / inventory) ───────────────────────────────────────────
SOURCE_TYPE=portal          # portal | fake
SOURCE_USERNAME=
SOURCE_PASSWORD=
SOURCE_BASE_URL=            # base URL for the source system API

# ── Sink system (notification / tracking board) ───────────────────────────────
SINK_TYPE=graphql           # graphql | null
SINK_API_TOKEN=
SINK_BOARD_ID=
SINK_DELIVERY_COL=          # column ID on the sink board that holds the delivery date

# ── Fleet config ──────────────────────────────────────────────────────────────
# Comma-separated truck IDs operated by this warehouse's own fleet.
# These are staged first in pick-queue order.
OWNED_FLEET_TRUCKS=56,58,62,68,72

# ── Secondary dim feed ────────────────────────────────────────────────────────
# URL template (with {model} placeholder) for fetching carton dimensions from
# an external product content catalog. Leave blank to skip.
DIM_FEED_URL_TEMPLATE=

# ── Warehouse layout ──────────────────────────────────────────────────────────
LAYOUT_JSON_PATH=    # absolute path to warehouse_layout.json

# ── Async fetch concurrency ───────────────────────────────────────────────────
SOURCE_DIM_CONCURRENCY=12
