# Normalize line endings: LF in repo, OS-native on checkout
* text=auto eol=lf

# Force LF for specific types
*.py   text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf

# Binary
*.png binary
*.jpg binary
*.pdf binary
